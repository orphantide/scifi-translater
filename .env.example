# ==========================================
# 环境变量模板文件 (.env)
# 部署说明：在本地使用时，复制此文件重命名为 .env 然后填入你的真实密钥。
# 在 Streamlit Community Cloud 发布时，请将这些内容填入应用的 Advanced settings -> Secrets 中。
# ==========================================

# 1. Gemini API 配置
GEMINI_API_KEY="AIzaSyYour...GeminiKeyHere"

# 2. OpenAI 兼容 API 配置 (如 DeepSeek, GPT-4, 本地大模型等)
OPENAI_API_KEY="sk-Your...OpenAIKeyHere"
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL_NAME="gpt-3.5-turbo"

# 3. 代理配置 (仅限国内本地环境使用)
# 如果服务器或云端（如 Streamlit官方云）不需要代理，请保持 USE_LOCAL_PROXY=false
USE_LOCAL_PROXY="false"
PROXY_PORT="7890"
